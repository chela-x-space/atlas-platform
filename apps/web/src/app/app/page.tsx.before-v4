const marketRows = [
  ["S&P 500", "5,347.89", "+0.83%"],
  ["NASDAQ", "17,168.42", "+1.45%"],
  ["DOW JONES", "38,711.29", "+0.67%"],
  ["NIKKEI 225", "38,470.38", "-0.31%"],
  ["GOLD", "2,315.60", "+0.28%"],
  ["OIL (Brent)", "79.45", "+2.32%"],
];

const aiRows = [
  ["OpenAI", "GPT-4o Update Released", "10:35"],
  ["Google DeepMind", "Gemini 1.5 Pro", "09:50"],
  ["Anthropic", "Claude 3.5 Sonnet", "08:20"],
  ["Meta AI", "Llama 3 Available", "Jun 7"],
  ["NVIDIA", "New AI Chip Announced", "Jun 7"],
];

const quakeRows = [
  ["M 5.2", "Taiwan Region", "09:58 UTC"],
  ["M 4.8", "Northern Chile", "09:42 UTC"],
  ["M 4.6", "Kermadec Islands", "09:28 UTC"],
  ["M 4.3", "Philippines", "09:12 UTC"],
  ["M 3.9", "Greece", "08:57 UTC"],
];

export default function AtlasDashboardPage() {
  const router = useRouter();

  const [activeMenu, setActiveMenu] =
    useState("Global Overview");

  const [activeLayer, setActiveLayer] =
    useState("All Layers");

  const [language, setLanguage] =
    useState<"TH" | "EN">("TH");

  const [mapScale, setMapScale] =
    useState(1);

  const [isThreeDimensional, setIsThreeDimensional] =
    useState(false);

  const [activeRange, setActiveRange] =
    useState("24H");

  const [marketTab, setMarketTab] =
    useState("Indices");

  const [searchValue, setSearchValue] =
    useState("");

  const [toastMessage, setToastMessage] =
    useState("");

  const [modal, setModal] = useState({
    open: false,
    title: "",
    description: "",
  });

  const menuRoutes: Record<string, string> = {
    "Global Overview": "/app",
    "World Map": "/app/monitor",
    "Event Timeline": "/app/timeline",
    "Breaking News": "/app/news",
    Earthquake: "/app/earthquake",
    "Weather & Climate": "/app/weather",
    "Economy & Markets": "/app/markets",
    "AI & Technology": "/app/ai",
    Settings: "/app/settings",
  };

  const filteredTimeline = useMemo(() => {
    const value = searchValue.trim().toLowerCase();

    if (!value) {
      return timeline;
    }

    return timeline.filter((item) =>
      `${item.title} ${item.detail}`
        .toLowerCase()
        .includes(value)
    );
  }, [searchValue]);

  function showToast(message: string) {
    setToastMessage(message);
  }

  function openModal(
    title: string,
    description: string
  ) {
    setModal({
      open: true,
      title,
      description,
    });
  }

  function closeModal() {
    setModal((current) => ({
      ...current,
      open: false,
    }));
  }

  function selectMenu(label: string) {
    setActiveMenu(label);

    const route = menuRoutes[label];

    if (route) {
      router.push(route);
      return;
    }

    showToast(`${label} module selected`);
  }

  function zoomMap(amount: number) {
    setMapScale((current) =>
      Math.min(1.45, Math.max(0.8, current + amount))
    );
  }

  function resetMap() {
    setMapScale(1);
    setIsThreeDimensional(false);
    showToast("Map view reset");
  }

  function handleSearch() {
    const value = searchValue.trim();

    if (!value) {
      showToast("Enter a location, topic or event");
      return;
    }

    showToast(`Searching ATLAS for “${value}”`);
  }

  useEffect(() => {
    if (!toastMessage) {
      return;
    }

    const timeout = window.setTimeout(() => {
      setToastMessage("");
    }, 2200);

    return () => window.clearTimeout(timeout);
  }, [toastMessage]);

  return (
    <div className="atlas-dashboard">
      <aside className="atlas-sidebar">
        <div className="atlas-brand">
          <div className="atlas-globe">🌐</div>

          <div>
            <strong>ATLAS</strong>
            <span>LIVING DASHBOARD</span>
            <small>OF PLANET EARTH</small>
          </div>
        </div>

        <div className="sidebar-scroll">
          {menuGroups.map((group) => (
            <section className="menu-group" key={group.title}>
              <p>{group.title}</p>

              {group.items.map(([icon, label]) => (
                <button
                  className={`sidebar-item ${
                    activeMenu === label ? "active" : ""
                  }`}
                  key={label}
                  type="button"
                  onClick={() => selectMenu(label)}
                >
                  <span>{icon}</span>
                  {label}
                </button>
              ))}
            </section>
          ))}

          <div className="mobile-card">
            <div className="mobile-card-icon">⌖</div>

            <div>
              <strong>ATLAS MOBILE</strong>
              <small>Stay informed anywhere</small>
            </div>

            <div className="store-buttons">
              <span>App Store</span>
              <span>Google Play</span>
            </div>
          </div>
        </div>

        <div className="social-row">
          <span>𝕏</span>
          <span>f</span>
          <span>▶</span>
          <span>◉</span>
          <span>◎</span>
        </div>
      </aside>

      <main className="atlas-main">
        <header className="atlas-header">
          <label className="atlas-search">
            <span>⌕</span>

            <input
              type="search"
              placeholder="Search for events, places, topics..."
              value={searchValue}
              onChange={(event) =>
                setSearchValue(event.target.value)
              }
              onKeyDown={(event) => {
                if (event.key === "Enter") {
                  handleSearch();
                }
              }}
            />

            <kbd>/</kbd>
          </label>

          <div className="header-actions">
            <button
              type="button"
              onClick={() => {
                setLanguage((current) =>
                  current === "TH" ? "EN" : "TH"
                );
                showToast(
                  language === "TH"
                    ? "Language changed to English"
                    : "เปลี่ยนภาษาเป็นภาษาไทย"
                );
              }}
            >
              🌐 {language}⌄
            </button>
            <button
              type="button"
              onClick={() =>
                showToast("No new system alerts")
              }
            >
              ♧
            </button>

            <button
              className="notification-button"
              type="button"
              onClick={() =>
                openModal(
                  "Notifications",
                  "ATLAS currently has 12 monitored notifications. Critical alerts will appear here when the live alert service is connected."
                )
              }
            >
              ♢
              <span>12</span>
            </button>

            <button
              type="button"
              onClick={() =>
                openModal(
                  "Share Dashboard",
                  "The public sharing workflow is ready for Backend integration."
                )
              }
            >
              ↗
            </button>
            <button
              className="login-button"
              type="button"
              onClick={() => router.push("/login")}
            >
              Login
            </button>
          </div>
        </header>

        <section className="metrics-row">
          {metrics.map((metric, index) => (
            <article className="metric-panel" key={metric.title}>
              <span>{metric.title}</span>

              <div className="metric-main">
                {index === 1 && <b className="metric-symbol">♡</b>}
                {index === 2 && <b className="metric-symbol">🙂</b>}
                {index === 3 && <b className="metric-symbol">◔</b>}
                {index === 6 && <b className="metric-symbol">🔥</b>}

                <strong>{metric.value}</strong>
              </div>

              <small className={metric.className}>{metric.status}</small>
            </article>
          ))}
        </section>

        <section className="dashboard-primary-grid">
          <div className="dashboard-left">
            <article className="map-card atlas-card">
              <div className="card-title-row">
                <div>
                  <h2>LIVE GLOBAL MAP</h2>
                </div>

                <span className="live-label">LIVE</span>
                <span className="events-detected">
                  ● 12,542 events detected
                </span>
              </div>

              <div className="map-layer-row">
                {[
                  "All Layers",
                  "Earthquake",
                  "Weather",
                  "Conflict",
                  "Flights",
                  "Ships",
                  "More Layers",
                ].map((layer) => (
                  <button
                    className={activeLayer === layer ? "active" : ""}
                    key={layer}
                    type="button"
                    onClick={() => setActiveLayer(layer)}
                  >
                    {layer}
                  </button>
                ))}
              </div>

              <div className="map-stage">
                <svg
                  className={`atlas-world-map ${
                    isThreeDimensional ? "map-3d" : ""
                  }`}
                  style={{
                    transform: `scale(${mapScale}) ${
                      isThreeDimensional
                        ? "perspective(900px) rotateX(8deg)"
                        : ""
                    }`,
                  }}
                  viewBox="0 0 1100 550"
                  role="img"
                  aria-label="ATLAS global event map"
                >
                  <defs>
                    <radialGradient id="ocean" cx="50%" cy="35%">
                      <stop offset="0%" stopColor="#123a62" />
                      <stop offset="65%" stopColor="#071d31" />
                      <stop offset="100%" stopColor="#020c16" />
                    </radialGradient>

                    <filter id="glow">
                      <feGaussianBlur stdDeviation="5" result="blur" />
                      <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                      </feMerge>
                    </filter>
                  </defs>

                  <rect width="1100" height="550" fill="url(#ocean)" />

                  <g className="map-grid-lines">
                    <path d="M0 90H1100M0 180H1100M0 270H1100M0 360H1100M0 450H1100" />
                    <path d="M110 0V550M220 0V550M330 0V550M440 0V550M550 0V550M660 0V550M770 0V550M880 0V550M990 0V550" />
                  </g>

                  <g className="continents">
                    <path d="M62 154L98 109L148 76L221 79L276 117L315 163L289 194L252 205L239 238L189 259L129 242L91 205L57 174Z" />
                    <path d="M236 267L282 258L323 294L333 347L315 407L282 474L250 426L231 364L216 309Z" />
                    <path d="M405 123L441 99L481 104L506 121L492 153L451 161L421 147Z" />
                    <path d="M467 179L526 169L572 201L584 253L568 322L532 402L495 436L459 384L445 322L446 246Z" />
                    <path d="M505 114L574 84L656 81L736 96L793 125L858 154L923 193L945 232L911 261L842 258L790 235L741 247L696 224L637 229L588 194L548 175Z" />
                    <path d="M830 326L883 301L951 319L990 355L969 392L919 414L862 399L831 365Z" />
                    <path d="M925 110L975 98L1005 119L982 151L944 154L916 132Z" />
                  </g>

                  <g className="city-lights">
                    {[
                      [118, 180],
                      [150, 155],
                      [190, 135],
                      [245, 170],
                      [274, 145],
                      [456, 140],
                      [492, 166],
                      [530, 190],
                      [616, 157],
                      [675, 145],
                      [730, 170],
                      [788, 198],
                      [830, 214],
                      [875, 190],
                      [914, 222],
                      [925, 360],
                      [865, 375],
                      [505, 300],
                      [540, 340],
                      [272, 355],
                      [231, 411],
                    ].map(([cx, cy], index) => (
                      <circle
                        cx={cx}
                        cy={cy}
                        fill="#ffc64f"
                        key={index}
                        opacity=".8"
                        r="2"
                      />
                    ))}
                  </g>

                  <g className="flight-paths">
                    <path d="M130 220Q400 75 760 160" />
                    <path d="M250 250Q520 120 915 230" />
                    <path d="M540 255Q710 115 960 180" />
                  </g>

                  <g className="event-markers" filter="url(#glow)">
                    {[
                      [128, 207, "red"],
                      [168, 154, "orange"],
                      [246, 176, "red"],
                      [279, 131, "red"],
                      [231, 403, "red"],
                      [507, 272, "red"],
                      [571, 229, "orange"],
                      [621, 178, "red"],
                      [708, 187, "orange"],
                      [787, 206, "red"],
                      [859, 212, "red"],
                      [916, 355, "orange"],
                    ].map(([cx, cy, type], index) => (
                      <g className={`map-marker ${type}`} key={index}>
                        <circle cx={cx} cy={cy} r="19" />
                        <circle cx={cx} cy={cy} r="10" />
                        <circle cx={cx} cy={cy} r="4" />
                      </g>
                    ))}

                    <g className="cyclone">
                      <circle cx="405" cy="445" r="34" />
                      <circle cx="405" cy="445" r="23" />
                      <circle cx="405" cy="445" r="10" />
                    </g>

                    <g className="cyclone">
                      <circle cx="665" cy="420" r="38" />
                      <circle cx="665" cy="420" r="25" />
                      <circle cx="665" cy="420" r="11" />
                    </g>
                  </g>

                  <g className="map-icons">
                    <text x="380" y="155">✈</text>
                    <text x="640" y="130">✈</text>
                    <text x="750" y="153">✈</text>
                    <text x="375" y="315">⛵</text>
                    <text x="662" y="236">⛵</text>
                    <text x="787" y="395">⛵</text>
                  </g>
                </svg>

                <div className="map-legend">
                  {[
                    ["▣", "Earthquake"],
                    ["◉", "Cyclone"],
                    ["▰", "Flood"],
                    ["🔥", "Wildfire"],
                    ["✕", "Conflict"],
                    ["▲", "Volcano"],
                    ["✈", "Flight"],
                    ["▰", "Ship"],
                  ].map(([icon, label]) => (
                    <span key={label}>
                      <b>{icon}</b>
                      {label}
                    </span>
                  ))}
                </div>

                <div className="map-tools">
                  <button
                    type="button"
                    className={
                      isThreeDimensional ? "active" : ""
                    }
                    onClick={() => {
                      setIsThreeDimensional(
                        (current) => !current
                      );
                      showToast(
                        isThreeDimensional
                          ? "2D map enabled"
                          : "3D map enabled"
                      );
                    }}
                  >
                    3D
                  </button>

                  <button
                    type="button"
                    onClick={() =>
                      showToast("Map layers panel opened")
                    }
                  >
                    ▱
                  </button>

                  <button
                    type="button"
                    onClick={() => zoomMap(0.1)}
                  >
                    ＋
                  </button>

                  <button
                    type="button"
                    onClick={() => zoomMap(-0.1)}
                  >
                    −
                  </button>

                  <button
                    type="button"
                    onClick={resetMap}
                  >
                    ⌾
                  </button>
                </div>

                <div className="map-timeline">
                  <div className="range-buttons">
                    {["24H", "7D", "30D", "1Y", "ALL"].map(
                      (range) => (
                        <button
                          type="button"
                          key={range}
                          className={
                            activeRange === range
                              ? "active"
                              : ""
                          }
                          onClick={() => {
                            setActiveRange(range);
                            showToast(
                              `Timeline range: ${range}`
                            );
                          }}
                        >
                          {range}
                        </button>
                      )
                    )}
                  </div>

                  <div className="timeline-axis">
                    <span>12:00</span>
                    <span>15:00</span>
                    <span>18:00</span>
                    <span>21:00</span>
                    <span>Jun 8</span>
                    <span>03:00</span>
                    <span>06:00</span>
                    <span>09:00</span>
                    <span>NOW</span>
                  </div>
                </div>
              </div>
            </article>

            <article className="timeline-card atlas-card">
              <div className="section-heading">
                <h2>GLOBAL TIMELINE</h2>
                <span>Live events</span>
              </div>

              <div className="timeline-grid">
                {filteredTimeline.map((item) => (
                  <article
                    className={`timeline-event ${item.type}`}
                    key={item.time}
                    role="button"
                    tabIndex={0}
                    onClick={() =>
                      openModal(
                        item.title,
                        `${item.detail} — detected at ${item.time}`
                      )
                    }
                    onKeyDown={(event) => {
                      if (
                        event.key === "Enter" ||
                        event.key === " "
                      ) {
                        openModal(
                          item.title,
                          `${item.detail} — detected at ${item.time}`
                        );
                      }
                    }}
                  >
                    <div>
                      <span>{item.time}</span>
                      <i>●</i>
                    </div>

                    <strong>{item.title}</strong>
                    <small>{item.detail}</small>
                  </article>
                ))}
              </div>
            </article>
          </div>

          <aside className="dashboard-right">
            <article className="summary-card atlas-card">
              <div className="section-heading">
                <h2>〽 AI GLOBAL SUMMARY</h2>
                <span>Updated 2 min ago</span>
              </div>

              <h3>วันนี้ความเสี่ยงของโลกเพิ่มขึ้น 8%</h3>

              <p>
                เนื่องจากแผ่นดินไหวรุนแรงในแปซิฟิก
                และความตึงเครียดทางภูมิรัฐศาสตร์ในตะวันออกกลาง
                อย่างไรก็ตามตลาดการเงินยังมีเสถียรภาพ
                และภาคเทคโนโลยียังคงเติบโตจากการเปิดตัวโมเดล AI รุ่นใหม่
              </p>

              <div className="summary-grid">
                <div>
                  <span>◉ Risk Level</span>
                  <b className="red">High</b>
                </div>

                <div>
                  <span>◉ Economic Impact</span>
                  <b className="orange">Moderate</b>
                </div>

                <div>
                  <span>◉ AI & Tech Outlook</span>
                  <b className="green">Positive</b>
                </div>

                <div>
                  <span>◉ Climate Outlook</span>
                  <b className="purple">Unstable</b>
                </div>
              </div>

              <div className="ai-orb">AI</div>

              <button
                className="report-button"
                type="button"
                onClick={() =>
                  openModal(
                    "AI Global Intelligence Report",
                    "The current global risk index increased by 8%. Major contributing signals include seismic activity, geopolitical tension and climate instability."
                  )
                }
              >
                View Full Report →
              </button>
            </article>

            <article className="quake-card atlas-card">
              <div className="section-heading">
                <h2 className="red">LIVE EARTHQUAKE</h2>
                <span>View All →</span>
              </div>

              <div className="quake-primary">
                <div>
                  <strong>M 6.4</strong>
                  <small>Strong Earthquake</small>

                  <h3>Near Hachijojima, Japan</h3>

                  <p>
                    Jun 8, 2024 10:15:23 UTC
                    <br />
                    Depth: 42 km
                    <br />
                    Tsunami Risk: <b className="green">Low</b>
                  </p>
                </div>

                <div className="quake-radar">
                  <span />
                  <span />
                  <span />
                  <b />
                </div>
              </div>

              <div className="quake-list">
                {quakeRows.map(([magnitude, place, time]) => (
                  <div key={place}>
                    <strong>{magnitude}</strong>
                    <span>{place}</span>
                    <small>{time}</small>
                  </div>
                ))}
              </div>
            </article>
          </aside>
        </section>

        <section className="bottom-dashboard-grid">
          <article className="atlas-card sentiment-card">
            <div className="section-heading">
              <h2>GLOBAL SENTIMENT INDEX</h2>
            </div>

            <p>Based on news, social, market and events</p>

            <div className="sentiment-gauge">
              <div className="gauge-arc" />
              <strong>-0.23</strong>
              <span>Neutral</span>
            </div>

            <div className="gauge-labels">
              <span>-2</span>
              <span>+2</span>
            </div>
          </article>

          <article className="atlas-card chart-card">
            <div className="section-heading">
              <h2>SENTIMENT TREND</h2>
              <span>7 Days</span>
            </div>

            <svg viewBox="0 0 320 150">
              <path
                className="chart-zero"
                d="M0 76H320"
              />

              <path
                className="chart-line-green"
                d="M0 76L20 48L40 62L60 31L80 63L100 83L120 92L140 85L160 72L180 64L200 48L220 77L240 122L260 101L280 61L300 79L320 72"
              />

              <path
                className="chart-line-red"
                d="M110 77L130 96L150 104L170 92L190 83"
              />
            </svg>

            <div className="chart-dates">
              <span>Jun 2</span>
              <span>Jun 4</span>
              <span>Jun 6</span>
              <span>Jun 8</span>
            </div>
          </article>

          <article className="atlas-card market-card">
            <div className="section-heading">
              <h2>MARKET OVERVIEW</h2>
            </div>

            <div className="market-tabs">
              <button type="button">Indices</button>
              <button type="button">Commodities</button>
              <button type="button">Crypto</button>
              <button type="button">Currencies</button>
            </div>

            <div className="market-table">
              {marketRows.map(([name, value, change]) => (
                <div key={name}>
                  <strong>{name}</strong>
                  <span>{value}</span>

                  <small className={change.startsWith("-") ? "red" : "green"}>
                    {change}
                  </small>
                </div>
              ))}
            </div>
          </article>

          <article className="atlas-card ai-radar-card">
            <div className="section-heading">
              <h2>AI & TECHNOLOGY RADAR</h2>
            </div>

            <p>Top AI News</p>

            <div className="ai-news-list">
              {aiRows.map(([company, news, time], index) => (
                <div key={company}>
                  <b className={`ai-news-icon color-${index}`}>◉</b>

                  <span>
                    <strong>{company}</strong>
                    <small>{news}</small>
                  </span>

                  <time>{time}</time>
                </div>
              ))}
            </div>

            <button
              className="panel-footer-button"
              type="button"
              onClick={() => router.push("/app/ai")}
            >
              View All AI News →
            </button>
          </article>

          <article className="atlas-card disaster-card">
            <div className="section-heading">
              <h2>DISASTER OVERVIEW</h2>
            </div>

            <p>Active Around the World</p>

            <div className="disaster-stats">
              <div>
                <b className="green">3</b>
                <span>Cyclones</span>
              </div>

              <div>
                <b className="red">56</b>
                <span>Wildfires</span>
              </div>

              <div>
                <b className="blue">9</b>
                <span>Floods</span>
              </div>

              <div>
                <b className="green">7</b>
                <span>Volcanoes</span>
              </div>
            </div>

            <div className="mini-map">
              <span className="mini-event one" />
              <span className="mini-event two" />
              <span className="mini-event three" />
              <span className="mini-event four" />
              <span className="mini-event five" />
            </div>

            <button
              className="panel-footer-button"
              type="button"
              onClick={() => router.push("/app/weather")}
            >
              View All Disasters →
            </button>
          </article>
        </section>

        <footer className="breaking-bar">
          <strong>BREAKING NEWS</strong>

          <div>
            <span>UN Urges Ceasefire in Gaza</span>
            <small>5 min ago</small>
          </div>

          <div>
            <span>NASA Launches New Earth Satellite</span>
            <small>12 min ago</small>
          </div>

          <div>
            <span>Hurricane Season Forecast Released</span>
            <small>25 min ago</small>
          </div>

          <div>
            <span>EU Passes AI Regulation Act</span>
            <small>32 min ago</small>
          </div>

          <div>
            <span>Bitcoin Reaches New High</span>
            <small>45 min ago</small>
          </div>
        </footer>
      </main>

      <DashboardToast message={toastMessage} />

      <DashboardModal
        open={modal.open}
        title={modal.title}
        description={modal.description}
        onClose={closeModal}
      />
    </div>
  );
}
